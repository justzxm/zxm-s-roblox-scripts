-- ==================== UTILITIES ====================
local function isValidTarget(part)
	if not part or not part.Parent then return false end
	if part.Anchored then return false end
	if not part:IsA("BasePart") then return false end
	if part.Size.Magnitude < 0.1 then return false end
	
	-- Skip character parts
	local p = part.Parent
	while p and p ~= workspace do
		if p:FindFirstChildOfClass("Humanoid") then return false end
		p = p.Parent
	end
	return true
end

local function grabPart(part)
	if controlled[part] then return end
	if not isValidTarget(part) then return end
	
	local origCC = part.CanCollide
	local origAnch = part.Anchored
	local origColor = part.Color
	local origMat = part.Material
	
	-- Near-zero mass for snappy response
	pcall(function()
		part.CustomPhysicalProperties = PhysicalProperties.new(0.01, 0.3, 0.5, 1, 1)
		part.Massless = true
		part.CanCollide = false
	end)
	
	local bp = Instance.new("BodyPosition")
	bp.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	bp.P = pullStrength
	bp.D = 8000
	bp.Position = part.Position
	bp.Parent = part
	
	local bg = Instance.new("BodyGyro")
	bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	bg.P = pullStrength
	bg.D = 8000
	bg.CFrame = part.CFrame
	bg.Parent = part
	
	controlled[part] = {
		origCC = origCC,
		origAnch = origAnch,
		origColor = origColor,
		origMat = origMat,
		bp = bp,
		bg = bg
	}
	partCount = partCount + 1
end

local function releasePart(part, data)
	if not data then return end
	pcall(function()
		if data.bp and data.bp.Parent then data.bp:Destroy() end
		if data.bg and data.bg.Parent then data.bg:Destroy() end
	end)
	pcall(function()
		if part and part.Parent then
			part.CanCollide = data.origCC
			part.Anchored = data.origAnch
			part.Color = data.origColor
			part.Material = data.origMat
			part.Massless = false
			part.CustomPhysicalProperties = nil
		end
	end)
end

local function releaseAll()
	for part, data in pairs(controlled) do
		releasePart(part, data)
	end
	controlled = {}
	partCount = 0
	isActive = false
	currentMode = "none"
end

local function sweepParts()
	local char = player.Character
	local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
	if not root then return end
	
	local pos = root.Position
	local grabbed = 0
	
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and not obj.Anchored and not controlled[obj] then
			local isChar = false
			local p = obj.Parent
			while p and p ~= workspace do
				if p:FindFirstChildOfClass("Humanoid") then isChar = true; break end
				p = p.Parent
			end
			if not isChar then
				-- Only grab if reasonably close (natural ownership range)
				if (obj.Position - pos).Magnitude < math.max(radius * 3, 60) then
					grabPart(obj)
					grabbed = grabbed + 1
					if grabbed % 50 == 0 then task.wait() end
				end
			end
		end
	end
end

-- ==================== SHAPE MATH ====================
local PHI = (1 + math.sqrt(5)) / 2

local function getShapePosition(mode, index, total, origin, charCF, t)
	local n = math.max(total, 1)
	local i = index - 1
	
	if mode == "heart" then
		local a = (i / n) * math.pi * 2
		local hx = 16 * math.sin(a)^3
		local hz = -(13 * math.cos(a) - 5 * math.cos(2*a) - 2 * math.cos(3*a) - math.cos(4*a))
		return origin + charCF:VectorToWorldSpace(Vector3.new(hx * (radius/16), 2, hz * (radius/16)))
		
	elseif mode == "wall" then
		local cols = math.max(1, math.ceil(math.sqrt(n)))
		local col = (i % cols) - math.floor(cols/2)
		local row = math.floor(i / cols) - math.floor(cols/2)
		return origin + charCF:VectorToWorldSpace(Vector3.new(col * 2.2, row * 2.2 + 2, radius))
		
	elseif mode == "box" then
		local faces = {
			charCF.LookVector, -charCF.LookVector,
			charCF.RightVector, -charCF.RightVector,
			charCF.UpVector, -charCF.UpVector
		}
		local fi = (i % 6) + 1
		local si = math.floor(i / 6)
		local sp = radius * 0.5
		local face = faces[fi]
		local tangent = (fi % 2 == 1) and charCF.RightVector or charCF.LookVector
		local bit = (si % 2 - 0.5) * sp
		local stack = (math.floor(si / 2) - 0.5) * sp
		return origin + face * radius + tangent * bit + charCF.UpVector * stack
		
	elseif mode == "ring" then
		local a = (i / n) * math.pi * 2 + t * 1.5
		return origin + Vector3.new(math.cos(a) * radius, 1.5 + math.sin(t + i*0.2)*0.5, math.sin(a) * radius)
		
	elseif mode == "sphere" then
		local theta = math.acos(math.clamp(1 - 2 * (i + 0.5) / n, -1, 1))
		local ang = 2 * math.pi * i / PHI + t * 0.5
		local r = radius * (0.9 + math.sin(t * 1.2 + i * 0.1) * 0.1)
		return origin + Vector3.new(
			r * math.sin(theta) * math.cos(ang),
			r * math.sin(theta) * math.sin(ang) + 2,
			r * math.cos(theta)
		)
		
	elseif mode == "spiral" then
		local turns = 3
		local h = (i / n) * turns * math.pi * 2
		local r = radius * (0.2 + 0.8 * (i / n))
		local y = (i / n) * radius * 1.5
		return origin + charCF:VectorToWorldSpace(Vector3.new(
			math.cos(h + t*2) * r,
			y + 2,
			math.sin(h + t*2) * r
		))
		
	elseif mode == "star" then
		local points = 5
		local outerR = radius
		local innerR = radius * 0.4
		local step = math.floor(i / 2)
		local isOuter = (i % 2) == 0
		local a = (step / (n/2)) * math.pi * 2 + t * 0.8
		local r = isOuter and outerR or innerR
		return origin + charCF:VectorToWorldSpace(Vector3.new(
			math.cos(a) * r,
			2 + (isOuter and 1 or 0),
			math.sin(a) * r
		))
		
	elseif mode == "diamond" then
		local layer = math.floor(i / 4)
		local side = i % 4
		local y = layer * 1.8
		local r = radius * (1 - layer / math.max(n/4, 1))
		local dirs = {
			Vector3.new(1, 0, 0), Vector3.new(0, 0, 1),
			Vector3.new(-1, 0, 0), Vector3.new(0, 0, -1)
		}
		return origin + charCF:VectorToWorldSpace(Vector3.new(
			dirs[side+1].X * r,
			y + 1,
			dirs[side+1].Z * r
		))
		
	elseif mode == "cross" then
		local arm = i % 3 -- 0=vertical, 1=right, 2=left
		local dist = math.floor(i / 3) * 1.6
		if arm == 0 then
			return origin + charCF:VectorToWorldSpace(Vector3.new(0, dist + 2, radius))
		elseif arm == 1 then
			return origin + charCF:VectorToWorldSpace(Vector3.new(dist, 2, radius))
		else
			return origin + charCF:VectorToWorldSpace(Vector3.new(-dist, 2, radius))
		end
		
	elseif mode == "wave" then
		local x = (i / n) * radius * 3 - radius * 1.5
		local z = math.sin(x * 0.8 + t * 3) * radius * 0.5
		return origin + charCF:VectorToWorldSpace(Vector3.new(x, 2 + math.cos(t*2 + i*0.3)*1, radius + z))
		
	elseif mode == "orbit" then
		local a = (i / n) * math.pi * 2 + t * (1 + spinSpeed)
		local r = radius + math.sin(t * 2 + i) * 0.5
		return origin + Vector3.new(math.cos(a) * r, 2.5, math.sin(a) * r)
		
	elseif mode == "helix" then
		local a = (i / n) * math.pi * 4 + t * 2
		local r = radius * 0.6
		local y = ((i / n) - 0.5) * radius * 2
		return origin + charCF:VectorToWorldSpace(Vector3.new(
			math.cos(a) * r,
			y + 3,
			math.sin(a) * r
		))
		
	elseif mode == "pyramid" then
		local layer = math.floor(math.sqrt(i))
		local layerI = i - (layer * layer)
		local layerN = (layer + 1) * (layer + 1) - (layer * layer)
		local a = (layerI / math.max(layerN, 1)) * math.pi * 2
		local r = radius * (1 - layer / math.max(math.sqrt(n), 1))
		return origin + charCF:VectorToWorldSpace(Vector3.new(
			math.cos(a) * r,
			layer * 1.5 + 1,
			math.sin(a) * r
		))
		
	else
		return origin + Vector3.new(0, 3, 0)
	end
end

-- ==================== MAIN LOOP ====================
RunService.Heartbeat:Connect(function(dt)
	if not scriptAlive then return end
	if not isActive or currentMode == "none" then return end
	
	spinAngle = spinAngle + spinSpeed * dt
	
	local char = player.Character
	local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
	if not root then return end
	
	local pos = root.Position
	local cf = root.CFrame
	local t = tick()
	
	-- Cleanup dead parts
	for part, data in pairs(controlled) do
		if not part or not part.Parent then
			controlled[part] = nil
			partCount = math.max(0, partCount - 1)
		end
	end
	
	local arr = {}
	for part, data in pairs(controlled) do
		if part and part.Parent then
			table.insert(arr, {part = part, data = data})
		end
	end
	local n = #arr
	
	for idx, item in ipairs(arr) do
		local part = item.part
		local data = item.data
		local targetPos = getShapePosition(currentMode, idx, n, pos, cf, t)
		
		-- Apply spin offset if enabled
		if spinSpeed ~= 0 then
			local phase = idx * (math.pi * 2 / math.max(n, 1))
			local offset = targetPos - pos
			local rotated = CFrame.fromAxisAngle(Vector3.new(0, 1, 0), spinAngle + phase) * offset
			targetPos = pos + rotated
		end
		
		pcall(function()
			if data.bp and data.bp.Parent then
				data.bp.P = pullStrength
				data.bp.D = 8000
				data.bp.MaxForce = Vector3.new(1e9, 1e9, 1e9)
				data.bp.Position = targetPos
			end
			if data.bg and data.bg.Parent then
				data.bg.P = pullStrength
				data.bg.D = 8000
				data.bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
				data.bg.CFrame = CFrame.new(targetPos, targetPos + cf.LookVector)
			end
		end)
	end
end)

