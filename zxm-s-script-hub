    toggleBtn.AnchorPoint = Vector2.new(1, 0)
    toggleBtn.Position = UDim2.new(1, -20, 0, 20)
    toggleBtn.Size = UDim2.new(0, 50, 0, 50)
    toggleBtn.BackgroundColor3 = Colors.Accent
    toggleBtn.Text = "ZS"
    toggleBtn.TextColor3 = Colors.TextPrimary
